# ─── Base de donnees ──────────────────────────────────
DATABASE_URL="postgresql://resa:resa_dev_password@localhost:5432/resa_esviere"

# ─── Serveur API ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Authentification JWT ─────────────────────────────
# Generer des secrets aleatoires : openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Emails (SMTP OVH en production) ─────────────────
# En dev, utiliser MailHog : localhost:1025, pas d'auth
# En production, utiliser le SMTP OVH de Fondacio
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=site.esviere@fondacio.fr
SMTP_PASS=
SMTP_FROM="Resa Esviere <site.esviere@fondacio.fr>"

# ─── Frontend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Uploads ──────────────────────────────────────────
UPLOAD_DIR=./uploads
